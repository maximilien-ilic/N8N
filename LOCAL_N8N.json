        224
      ],
      "id": "2c63d921-b110-4451-b876-879ab1c46d51",
      "name": "GET",
      "credentials": {
        "githubApi": {
          "id": "5YJSfkBSdWhpgUvt",
          "name": "GitHub account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const files = $input.all().map(i => i.json);\n\nconst SKIP = ['.lock', '.png', '.jpg', '.jpeg', '.svg',\n              '.gif', '.ico', '.woff', '.woff2', '.ttf'];\n\nconst relevant = files.filter(f => {\n  const ext = '.' + f.filename.split('.').pop().toLowerCase();\n  return !SKIP.includes(ext) && f.status !== 'removed' && f.patch;\n});\n\nif (relevant.length === 0) {\n  return [{ json: { skip: true } }];\n}\n\nconst codeBlock = relevant.map(f =>\n  `### ${f.filename}\\n\\`\\`\\`diff\\n${(f.patch || '').substring(0, 4000)}\\n\\`\\`\\``\n).join('\\n\\n');\n\nconst prNumber = $('IF').first().json.number;\n\nreturn [{\n  json: {\n    pr_number:  prNumber,\n    pr_title:   'Audit sécurité automatique',\n    pr_author:  'maximilien-ilic',\n    head_sha:   '',\n    repo:       'maximilien-ilic/Portfolio',\n    file_count: relevant.length,\n    prompt_payload: {\n      model: \"claude-sonnet-4-6\",\n      max_tokens: 3000,\n      system: \"Tu es un expert en sécurité applicative. Tu analyses des diffs de Pull Requests et réponds UNIQUEMENT en JSON valide, sans markdown.\",\n      messages: [{\n        role: \"user\",\n        content: `Analyse ce diff et réponds en JSON :\\n\\n${codeBlock}\\n\\n{\\n  \"overall_risk\": \"critical|high|medium|low|safe\",\\n  \"summary\": \"Résumé en 2 phrases\",\\n  \"vulnerabilities\": [{\"file\":\"...\",\"severity\":\"critical|high|medium|low\",\"category\":\"xss|injection|secrets|auth|crypto|other\",\"title\":\"...\",\"description\":\"...\",\"remediation\":\"...\"}],\\n  \"secrets_detected\": [],\\n  \"block_merge\": false,\\n  \"security_positives\": []\\n}`\n      }]\n    }\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        960,
        224
      ],
      "id": "1fa6e755-c05b-4022-9e22-5f66385321ec",
      "name": "PROMPT"
    },
