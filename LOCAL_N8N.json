    {
      "parameters": {
        "jsCode": "const body = $json.body;\nconst action = body.action;\n\nif (!['opened', 'synchronize', 'reopened'].includes(action)) {\n  return [];\n}\n\nreturn [{\n  json: {\n    action: action,\n    number: body.number,\n    pr_title: body.pull_request.title,\n    pr_author: body.pull_request.user.login,\n    head_sha: body.pull_request.head.sha,\n    repo: 'maximilien-ilic/Portfolio'\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        448,
        256
      ],
      "id": "87529dc0-5985-4f49-ba04-53349f1540f9",
      "name": "IF"
    },
    {
      "parameters": {
        "url": "=https://api.github.com/repos/maximilien-ilic/Portfolio/pulls/{{ $json.number}}/files",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "githubApi",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "accept",
              "value": "application/vnd.github.v3+json"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
