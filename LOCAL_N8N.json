      "id": "69ef7f52-c905-4c47-b7c5-73574c87c0cd",
      "name": "POST COMMENT",
      "credentials": {
        "githubApi": {
          "id": "5YJSfkBSdWhpgUvt",
          "name": "GitHub account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const claudeRaw = $input.first().json.content[0].text;\nconst pr = $('PROMPT').first().json;\n\nlet analysis;\ntry {\n  analysis = JSON.parse(claudeRaw.replace(/```json\\n?|\\n?```/g, '').trim());\n} catch(e) {\n  analysis = {\n    overall_risk: 'medium',\n    summary: claudeRaw,\n    vulnerabilities: [],\n    secrets_detected: [],\n    block_merge: false,\n    security_positives: []\n  };\n}\n\nconst emoji = { critical:'🔴', high:'🟠', medium:'🟡', low:'🟢', safe:'✅' };\nconst sevLabel = { critical:'🔴 Critique', high:'🟠 Haute', medium:'🟡 Moyenne', low:'🟢 Faible' };\n\nlet comment = `## ${emoji[analysis.overall_risk] || '⚪'} Audit sécurité — Risque **${(analysis.overall_risk || 'inconnu').toUpperCase()}**\\n\\n`;\ncomment += `> ${analysis.summary}\\n\\n`;\ncomment += `*Analysé par Claude · ${pr.file_count} fichier(s) · ${new Date().toLocaleDateString('fr-FR')}*\\n\\n`;\n\nif (analysis.secrets_detected?.length > 0) {\n  comment += `---\\n### ⚠️ Secrets détectés\\n`;\n  analysis.secrets_detected.forEach(s => {\n    comment += `- **${s.type}** dans \\`${s.file}\\`\\n`;\n  });\n  comment += '\\n';\n}\n\nif (analysis.vulnerabilities?.length > 0) {\n  comment += `---\\n### Vulnérabilités (${analysis.vulnerabilities.length})\\n\\n`;\n  analysis.vulnerabilities.forEach(v => {\n    comment += `<details>\\n<summary>${sevLabel[v.severity] || v.severity} — ${v.title} · <code>${v.file}</code></summary>\\n\\n`;\n    comment += `**Catégorie** : ${v.category}\\n\\n`;\n    comment += `**Problème** : ${v.description}\\n\\n`;\n    comment += `**Correction** : ${v.remediation}\\n\\n`;\n    comment += `</details>\\n\\n`;\n  });\n} else {\n  comment += `---\\n### ✅ Aucune vulnérabilité détectée\\n\\n`;\n}\n\nif (analysis.security_positives?.length > 0) {\n  comment += `---\\n### Bonnes pratiques\\n`;\n  analysis.security_positives.forEach(p => comment += `- ${p}\\n`);\n}\n\nreturn [{\n  json: {\n    pr_number:      pr.pr_number,\n    repo:           pr.repo,\n    head_sha:       pr.head_sha,\n    github_comment: comment,\n    block_merge:    analysis.block_merge || false,\n    overall_risk:   analysis.overall_risk\n  }\n}];"
      },
